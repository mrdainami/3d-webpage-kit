# Copy this file to ".env" and fill in your own keys. Never commit your real .env.

# kie.ai — powers the AI product-hero animation (Nano Banana stills + Seedance video).
# Get a key: https://kie.ai  ->  Dashboard -> API Keys.  Only needed for the scroll-hero pipeline.
KIE_API_KEY=

# Cloudflare — powers "launch" (deploy). Get a token:
# https://dash.cloudflare.com/profile/api-tokens -> Create Token -> "Edit Cloudflare Workers".
# (Any static host works too — Netlify / Vercel / GitHub Pages — Cloudflare is just the default.)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
